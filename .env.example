# ─── Server ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Atlassian OAuth 2.0 (Jira) ───────────────────────────
# Create an OAuth 2.0 app at: https://developer.atlassian.com/console/myapps/
# Required scopes: read:jira-user read:jira-work write:jira-work offline_access
ATLASSIAN_CLIENT_ID=your_atlassian_client_id
ATLASSIAN_CLIENT_SECRET=your_atlassian_client_secret
ATLASSIAN_REDIRECT_URI=http://localhost:3000/auth/jira/callback

# Optional: default Jira project key when tools omit project_key (prefix from SCRUM-1 → SCRUM)
DEFAULT_JIRA_PROJECT_KEY=

# Optional: override the Bitbucket workspace slug stored during OAuth (useful when account username ≠ workspace slug)
DEFAULT_BITBUCKET_WORKSPACE=

# ─── Bitbucket OAuth 2.0 ──────────────────────────────────
# OAuth consumer: https://support.atlassian.com/bitbucket-cloud/docs/use-oauth-on-bitbucket-cloud/
BITBUCKET_CLIENT_ID=your_bitbucket_client_id
BITBUCKET_CLIENT_SECRET=your_bitbucket_client_secret
BITBUCKET_REDIRECT_URI=http://localhost:3000/auth/bitbucket/callback

# ─── Database ─────────────────────────────────────────────
DATABASE_PATH=./data/flow.db

# ─── Security ─────────────────────────────────────────────
ENCRYPTION_KEY=change_me_to_a_random_32_char_secret_key

# ─── MCP ──────────────────────────────────────────────────
REQUIRE_CONFIRMATIONS=false
